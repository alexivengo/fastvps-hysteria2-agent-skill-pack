# Copy to .env locally if you want a private operator-side parameter file.
# Do not commit a real .env with live values.

# VPS access
HY2_HOST=203.0.113.10
HY2_SSH_USER=root
HY2_SSH_PORT=22
HY2_SSH_KEY=~/.ssh/id_ed25519

# Deployment mode: self-signed or acme
HY2_TLS_MODE=self-signed

# Required only for ACME mode
HY2_DOMAIN=hy2.example.com
HY2_EMAIL=user@example.com

# Optional overrides
HY2_LISTEN_PORT=
HY2_AUTH_PASSWORD=
HY2_OUTPUT_DIR=./artifacts/fastvps-hysteria2

# Set to 1 when you want deployment without writing connection.env or client URIs locally
HY2_NO_LOCAL_SECRETS=1
